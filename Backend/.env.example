# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-generated-secret
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql://postgres:your-password@localhost:5432/fxguard
FRONTEND_URL=https://your-frontend.vercel.app
FRONTEND_BASE_URL=https://your-frontend.vercel.app

# Email
GMAIL_ADDRESS=your-email@gmail.com
GMAIL_PASSWORD=your-app-password
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=465
SMTP_USE_SSL=true
SMTP_USE_TLS=false
SMTP_TIMEOUT_SECONDS=30

# Interswitch API Credentials
# Obtain from https://developer.interswitchgroup.com
# Use sandbox credentials during development
INTERSWITCH_BASE_URL=https://sandbox.interswitchng.com
INTERSWITCH_AUTH_BASE_URL=https://qa.interswitchng.com
INTERSWITCH_CLIENT_ID=your-interswitch-client-id
INTERSWITCH_CLIENT_SECRET=your-interswitch-client-secret
INTERSWITCH_MERCHANT_CODE=your-merchant-code
INTERSWITCH_PAYABLE_CODE=your-payable-code

# Claude API - used to explain live FX indicators in plain English
ANTHROPIC_API_KEY=your-anthropic-api-key-here
# Optional Anthropic model override
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# ExchangeRate API - used to ingest latest FX rates into the local history store
EXCHANGE_RATE_API_KEY=your-exchangerate-api-key-here
# Optional override for provider base URL
EXCHANGE_RATE_API_BASE_URL=https://v6.exchangerate-api.com/v6
# Number of days to seed when historical access is unavailable
FX_HISTORY_SEED_DAYS=30

# Twelve Data - used for intraday FX candles when daily history is insufficient
TWELVE_DATA_API_KEY=your-twelve-data-api-key-here
TWELVE_DATA_BASE_URL=https://api.twelvedata.com
